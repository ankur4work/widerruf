# Shopify App Credentials (get these from your Shopify Partner Dashboard)
SHOPIFY_API_KEY=REPLACE_WITH_YOUR_SHOPIFY_API_KEY
SHOPIFY_API_SECRET=REPLACE_WITH_YOUR_SHOPIFY_API_SECRET

# Public app URL
SHOPIFY_APP_URL=https://widerruf.onkra.online

# Scopes
SCOPES=read_orders

# Database (PostgreSQL on Coolify)
DATABASE_URL=postgresql://user:password@host:5432/widerruf
DIRECT_URL=postgresql://user:password@host:5432/widerruf

# Runtime
NODE_ENV=production
PORT=3000

# Confirmation email (SMTP). On free plan we use a shared sender; paid uses custom domain.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Withdrawal <no-reply@widerruf.onkra.online>"

# Billing (free vs paid plan)
SHOPIFY_BILLING_TEST=true
BILLING_CURRENCY=USD
BILLING_INTERVAL=EVERY_30_DAYS
BILLING_PRO_NAME=PRO
BILLING_PRO_PRICE=7
BILLING_PRO_TRIAL_DAYS=7
