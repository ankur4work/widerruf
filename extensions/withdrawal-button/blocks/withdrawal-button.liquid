{% comment %}
  Widerruf: EU Withdrawal Button — App Embed block.
  Additive only: links to the proxy page /apps/withdrawal.
  The small "Powered by Widerruf" line sits INSIDE the button box on the Free
  plan; widerruf-brand.js hides it on Pro (checks /apps/withdrawal/status).
{% endcomment %}

{% assign label = block.settings.label | default: 'Withdraw from contract' %}
{% assign accent = block.settings.accent_color | default: '#2563EB' %}
{% assign href = '/apps/withdrawal' %}
{% assign side = block.settings.side | default: 'right' %}

{% if block.settings.mode == 'floating' %}
  <a
    href="{{ href }}"
    class="widerruf-btn--floating"
    style="background:{{ accent }};{{ side }}:18px;"
    rel="nofollow"
  >
    <span class="widerruf-btn__label">{{ label }}</span>
    <span class="widerruf-brand">Powered by Widerruf</span>
  </a>
{% else %}
  <div class="widerruf-footer">
    <a href="{{ href }}" class="widerruf-link" rel="nofollow">{{ label }}</a>
    <span class="widerruf-brand widerruf-brand--footer">Powered by Widerruf</span>
  </div>
{% endif %}

<script src="{{ 'widerruf-brand.js' | asset_url }}" defer></script>

<style>
  .widerruf-footer { text-align: center; padding: 14px 10px; }
  .widerruf-link { color: {{ accent }}; text-decoration: underline; font-size: 14px; }
  .widerruf-btn--floating {
    position: fixed;
    bottom: 18px;
    z-index: 999998;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    color: #fff;
    padding: 9px 18px;
    border-radius: 16px;
    text-decoration: none;
    box-shadow: 0 4px 14px rgba(0,0,0,.18);
    line-height: 1.2;
  }
  .widerruf-btn__label { font-size: 14px; font-weight: 600; }
  .widerruf-brand { font-size: 9px; opacity: .8; }
  .widerruf-btn--floating .widerruf-brand { color: rgba(255,255,255,.85); }
  .widerruf-brand--footer { display: block; margin-top: 3px; color: #8a8a98; }
</style>

{% schema %}
{
  "name": "Widerruf Button",
  "target": "body",
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "label": "Placement",
      "options": [
        { "value": "footer", "label": "Footer link" },
        { "value": "floating", "label": "Floating button" }
      ],
      "default": "footer"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Button label",
      "info": "Use a legally unambiguous label, e.g. 'Withdraw from contract' / 'Vertrag widerrufen'.",
      "default": "Withdraw from contract"
    },
    {
      "type": "select",
      "id": "side",
      "label": "Floating side",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#2563EB"
    }
  ]
}
{% endschema %}
