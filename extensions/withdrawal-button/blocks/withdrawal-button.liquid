{% comment %}
  Widerruf: EU Withdrawal Button — App Embed block.
  Additive only: links to the proxy page /apps/withdrawal.
  Shows a small "Powered by Widerruf" tag on the Free plan (hidden on Pro via
  widerruf-brand.js, which checks /apps/withdrawal/status). No theme changes.
{% endcomment %}

{% assign label = block.settings.label | default: 'Withdraw from contract' %}
{% assign accent = block.settings.accent_color | default: '#2563EB' %}
{% assign href = '/apps/withdrawal' %}
{% assign side = block.settings.side | default: 'right' %}

{% if block.settings.mode == 'floating' %}
  <div class="widerruf-floatwrap" style="{{ side }}:18px;">
    <a href="{{ href }}" class="widerruf-btn--floating" style="background:{{ accent }};" rel="nofollow">{{ label }}</a>
    <div class="widerruf-brand">Powered by <a href="https://widerruf.onkra.online" target="_blank" rel="noopener">Widerruf</a></div>
  </div>
{% else %}
  <div class="widerruf-footer">
    <a href="{{ href }}" class="widerruf-link" rel="nofollow">{{ label }}</a>
    <div class="widerruf-brand">Powered by <a href="https://widerruf.onkra.online" target="_blank" rel="noopener">Widerruf</a></div>
  </div>
{% endif %}

<script src="{{ 'widerruf-brand.js' | asset_url }}" defer></script>

<style>
  .widerruf-footer { text-align: center; padding: 14px 10px; }
  .widerruf-link { color: {{ accent }}; text-decoration: underline; font-size: 14px; }
  .widerruf-floatwrap {
    position: fixed;
    bottom: 18px;
    z-index: 999998;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .widerruf-btn--floating {
    color: #fff;
    padding: 11px 16px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 14px rgba(0,0,0,.18);
  }
  .widerruf-brand { font-size: 10px; line-height: 1.3; color: #8a8a98; text-align: center; }
  .widerruf-brand a { color: #8a8a98; text-decoration: underline; }
</style>

{% schema %}
{
  "name": "Widerruf Button",
  "target": "body",
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "label": "Placement",
      "options": [
        { "value": "footer", "label": "Footer link" },
        { "value": "floating", "label": "Floating button" }
      ],
      "default": "footer"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Button label",
      "info": "Use a legally unambiguous label, e.g. 'Withdraw from contract' / 'Vertrag widerrufen'.",
      "default": "Withdraw from contract"
    },
    {
      "type": "select",
      "id": "side",
      "label": "Floating side",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#2563EB"
    }
  ]
}
{% endschema %}
