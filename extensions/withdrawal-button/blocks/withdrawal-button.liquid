{% comment %}
  Widerruf: EU Withdrawal Button — App Embed block.
  Additive only: links to the proxy page /apps/withdrawal.
  Never modifies or disables theme sections. No JavaScript (CSP-safe).
{% endcomment %}

{% assign label = block.settings.label | default: 'Withdraw from contract' %}
{% assign accent = block.settings.accent_color | default: '#2563EB' %}
{% assign href = '/apps/withdrawal' %}

{% if block.settings.mode == 'floating' %}
  <a
    href="{{ href }}"
    class="widerruf-btn widerruf-btn--floating"
    style="background:{{ accent }};"
    rel="nofollow"
  >{{ label }}</a>
{% else %}
  <div class="widerruf-footer">
    <a href="{{ href }}" class="widerruf-link" rel="nofollow">{{ label }}</a>
  </div>
{% endif %}

<style>
  .widerruf-footer { text-align: center; padding: 14px 10px; }
  .widerruf-link {
    color: {{ accent }};
    text-decoration: underline;
    font-size: 14px;
  }
  .widerruf-btn--floating {
    position: fixed;
    bottom: 18px;
    {{ block.settings.side | default: 'right' }}: 18px;
    z-index: 999998;
    color: #fff;
    padding: 11px 16px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 14px rgba(0,0,0,.18);
  }
</style>

{% schema %}
{
  "name": "Widerruf Button",
  "target": "body",
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "label": "Placement",
      "options": [
        { "value": "footer", "label": "Footer link" },
        { "value": "floating", "label": "Floating button" }
      ],
      "default": "footer"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Button label",
      "info": "Use a legally unambiguous label, e.g. 'Withdraw from contract' / 'Vertrag widerrufen'.",
      "default": "Withdraw from contract"
    },
    {
      "type": "select",
      "id": "side",
      "label": "Floating side",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#2563EB"
    }
  ]
}
{% endschema %}
